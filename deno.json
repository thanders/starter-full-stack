{
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@faker-js/faker": "npm:@faker-js/faker@^10.3.0",
    "@hono/zod-validator": "npm:@hono/zod-validator@^0.7.6",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "better-sqlite3": "npm:better-sqlite3@^12.6.2",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "hono": "jsr:@hono/hono@^4.12.3",
    "zod": "npm:zod@^4.3.6"
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "build:fe": "cd frontend && npm run build",
    "db:push": "deno run -A --node-modules-dir=auto npm:drizzle-kit push --config=drizzle.config.ts",
    "db:seed": "deno run -A db/seed.ts",
    "dev": "deno run -A --watch main.ts",
    "start": "deno run -A main.ts"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  }
}
